/*14. Escreva uma função que calcule a somatória dos n primeiros números de um conjunto. O valor de n
deverá ser fornecido pelo usuário.*/

#include <stdio.h>

int somatoria(int n) {
    int soma = 0;

    for(int i = 1; i <= n; i++) {
        soma += i;
    }

    return soma;
}

int main(){
    int n;
    
    printf("defina a quantidade de termos: ");
    scanf("%d",&n);
    
    somatoria(n);
}
