#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    
    int i, num;
    int cont[101] = {0}; // contador de 0 a 100

    int maior = 0, menor = 100;
    int maisFreq = 0, menosFreq = 0;

    srand(time(NULL));

    // sorteio de 1000 números
    
    for(i = 0; i < 1000; i++) {
        num = rand() % 101; // 0 a 100
        cont[num]++;

        // maior número sorteado
        if(num > maior) {
            maior = num;
        }

        // menor número sorteado
        if(num < menor) {
            menor = num;
        }
    }

    // descobrir mais e menos frequente
    maisFreq = 0;
    menosFreq = 0;

    for(i = 1; i < 101; i++) {
        if(cont[i] > cont[maisFreq]) {
            maisFreq = i;
        }

        if(cont[i] < cont[menosFreq]) {
            menosFreq = i;
        }
    }

    // resultados
    printf("Numero mais frequente: %d (apareceu %d vezes)\n", maisFreq, cont[maisFreq]);
    printf("Numero menos frequente: %d (apareceu %d vezes)\n", menosFreq, cont[menosFreq]);
    printf("Maior numero sorteado: %d\n", maior);
    printf("Menor numero sorteado: %d\n", menor);

    return 0;
}
