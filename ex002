#include <stdio.h>
    
float conversao (float f){
        
        return (5.0/9.0)*(f-32);
        
}

int main(){
    float f, resultado = 0.0;
    
        printf("temperatura: ");
        scanf("%f",&f);
    
        resultado = conversao(f);
    
        printf("convertido: %.2f",resultado);

    return 0;
}
